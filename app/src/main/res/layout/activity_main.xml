<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:id="@+id/title_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:text="LogKiller"
        android:textColor="@color/accent_cyan"
        android:textSize="48sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <!-- Cards Container -->
    <LinearLayout
        android:id="@+id/cards_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/title_text"
        android:layout_above="@id/buttons_container"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="3">

        <!-- Card 1: Current Log Limit -->
        <LinearLayout
            android:id="@+id/card1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="12dp"
            android:background="@color/card_background"
            android:orientation="vertical"
            android:padding="20dp"
            android:focusable="true"
            android:clickable="true"
            android:nextFocusRight="@+id/card2"
            android:nextFocusDown="@+id/fix_button">

            <TextView
                android:id="@+id/card1_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Current Log Limit"
                android:textColor="@android:color/darker_gray"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/card1_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="-- MB"
                android:textColor="@color/status_red"
                android:textSize="32sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Card 2: Log Folder Size -->
        <LinearLayout
            android:id="@+id/card2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="12dp"
            android:background="@color/card_background"
            android:orientation="vertical"
            android:padding="20dp"
            android:focusable="true"
            android:clickable="true"
            android:nextFocusLeft="@+id/card1"
            android:nextFocusRight="@+id/card3"
            android:nextFocusDown="@+id/fix_button">

            <TextView
                android:id="@+id/card2_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Log Folder Size"
                android:textColor="@android:color/darker_gray"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/card2_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="-- MB"
                android:textColor="@color/status_yellow"
                android:textSize="32sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Card 3: Available Storage -->
        <LinearLayout
            android:id="@+id/card3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="12dp"
            android:background="@color/card_background"
            android:orientation="vertical"
            android:padding="20dp"
            android:focusable="true"
            android:clickable="true"
            android:nextFocusLeft="@+id/card2"
            android:nextFocusDown="@+id/fix_button">

            <TextView
                android:id="@+id/card3_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Available Storage"
                android:textColor="@android:color/darker_gray"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/card3_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="-- MB / -- MB"
                android:textColor="@color/accent_cyan"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- Buttons Container -->
    <LinearLayout
        android:id="@+id/buttons_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/status_text"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <!-- FIX NOW Button -->
        <Button
            android:id="@+id/fix_button"
            android:layout_width="300dp"
            android:layout_height="72dp"
            android:text="@string/fix_now"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:background="@drawable/button_fix"
            android:focusable="true"
            android:clickable="true"
            android:nextFocusUp="@+id/card1"
            android:nextFocusDown="@+id/restore_button" />

        <!-- Restore Defaults Button -->
        <Button
            android:id="@+id/restore_button"
            android:layout_width="300dp"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="@string/restore_defaults"
            android:textColor="@android:color/darker_gray"
            android:textSize="18sp"
            android:background="@drawable/button_restore"
            android:focusable="true"
            android:clickable="true"
            android:enabled="false"
            android:nextFocusUp="@+id/fix_button"
            android:nextFocusDown="@+id/copy_adb_button" />

        <!-- Copy ADB Commands Button -->
        <Button
            android:id="@+id/copy_adb_button"
            android:layout_width="300dp"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="@string/copy_adb_commands"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:background="@drawable/button_adb"
            android:focusable="true"
            android:clickable="true"
            android:nextFocusUp="@+id/restore_button"
            android:visibility="gone" />

        <!-- Retry Button -->
        <Button
            android:id="@+id/retry_button"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="@string/retry"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:background="@drawable/button_retry"
            android:focusable="true"
            android:clickable="true"
            android:visibility="gone"
            android:nextFocusUp="@+id/copy_adb_button" />

    </LinearLayout>

    <!-- Status Text -->
    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginTop="16dp"
        android:background="@color/card_background"
        android:padding="16dp"
        android:text="Initializing..."
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:maxLines="6"
        android:scrollbars="vertical"
        android:fontFamily="monospace" />

</RelativeLayout>
